{
  "expo": {
    "name": "Kingdoom",
    "slug": "kingdoom-native",
    "version": "1.0.1-beta.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kingdoom",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060606"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reborn.app",
      "buildNumber": "10101"
    },
    "android": {
      "package": "com.reborn.app",
      "versionCode": 10101,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#060606"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "project": "kingdoom-native",
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    }
  }
}
